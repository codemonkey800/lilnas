{
  "name": "@lilnas/swole",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "packageManager": "pnpm@10.18.2",
  "prettier": "@lilnas/prettier",
  "files": [
    "./.next"
  ],
  "scripts": {
    "build": "next build",
    "clean": "rm -rf .next/ .turbo/",
    "db:generate": "drizzle-kit generate",
    "dev": "lilnas dev",
    "dev:start": "next dev -p ${PORT:-8080}",
    "lint": "run-p -l 'lint:!(fix)'",
    "lint:eslint": "eslint src",
    "lint:prettier": "prettier -c src",
    "lint:fix": "run-p -l lint:*:fix",
    "lint:eslint:fix": "eslint --fix src",
    "lint:prettier:fix": "prettier -w src",
    "start": "NODE_ENV=production node server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@lilnas/utils": "workspace:*",
    "@mui/icons-material": "7.3.4",
    "@mui/material": "7.3.4",
    "@mui/material-nextjs": "7.3.10",
    "better-sqlite3": "^12.10.0",
    "clsx": "2.1.1",
    "dotenv": "17.2.3",
    "drizzle-orm": "^0.45.1",
    "next": "16.2.2",
    "npm-run-all": "4.1.5",
    "pino": "10.3.1",
    "prom-client": "^15.1.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "3.3.1",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@lilnas/cli": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "29.5.14",
    "drizzle-kit": "^0.31.9",
    "jest": "29.7.0",
    "pino-pretty": "13.1.2",
    "ts-jest": "29.2.6",
    "typescript": "5.9.3"
  }
}
