# -----------------------------------------------------------------------------
# Production note (Phase D / U7): unlike every other lilnas app, tdr-code's
# NestJS (:8082) and Next.js (:8080) processes run directly on the deploy
# host, not inside the `deploy.yml` Docker container (that container is only
# an nginx reverse proxy — see deploy.yml's `image: nginx:alpine` and its
# `host.docker.internal:8080` healthcheck target). There is no
# `infra/.env.tdr-code` file and nothing in this app's code would ever read
# one, because the host process is never inside the container Docker Compose
# would inject an `env_file:` into.
#
# In production, the CONTENTS of this file (never this file itself, and never
# committed) become the real `.env` placed in the host process's working
# directory, loaded automatically by the `dotenv.config()` call already
# present in both `src/main.ts` and `src/bot-main.ts` — the exact mechanism
# already used in dev via this same `apps/tdr-code/.env` convention. See
# `docs/runbooks/tdr-code-phase-d-forward-auth-cutover.md` for the full
# secrets-provisioning procedure.
# -----------------------------------------------------------------------------

# Port for the NestJS backend server.
# Default: 8082
#BACKEND_PORT=8082

# Port for the Next.js frontend server.
# Default: 8080. Unlike BACKEND_PORT, this has no code-level fallback --
# dev:frontend runs via dotenv-cli, and `next dev` defaults to 3000 with no
# PORT var at all -- so this must stay uncommented.
PORT=8080

# Discord bot token.
DISCORD_API_TOKEN=

# Discord guild ID for registering slash commands in development.
DISCORD_GUILD_ID=

# Phase D: Discord OAuth2 client id + secret for "Login with Discord" (Better
# Auth). Get these from the Discord Developer Portal's OAuth2 page for the
# SAME Application as the bot (Application > OAuth2 > Client information) —
# they are distinct from DISCORD_API_TOKEN (the Bot page's token), which the
# bot process uses to connect to Discord's gateway, not to authenticate web
# users.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# GitHub-linking plan: GitHub OAuth App client id + secret for the
# self-service "Link GitHub" flow (Better Auth account-linking, not sign-in).
# One-time setup: register a new OAuth App at
# https://github.com/settings/applications/new with callback URL
# https://tdr-code.lilnas.io/api/auth/callback/github (mirrors the
# already-registered Discord callback above), then copy its Client ID and
# generate a Client Secret from the same App's page.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Phase D: Better Auth session-signing secret. This is a generated random
# secret, NOT something Discord issues — generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Phase D: allowed Origin for mutating console routes (POST/PUT/DELETE) --
# see requireSameOrigin() in git-identity.controller.ts / config.controller.ts
# / lifecycle.controller.ts / auth-admin.controller.ts. Defaults to
# 'https://tdr-code.lilnas.io' (production) when unset, which rejects every
# mutating request from a local dev origin with "cross-origin request
# rejected". Set this to match PORT above, e.g. for local dev:
#   http://localhost:8080
ALLOWED_CONSOLE_ORIGIN=

# Phase D: Public base URL the app is served at, used to build the Discord
# OAuth redirect_uri and to derive secure-cookie defaults.
# Example: https://tdr-code.lilnas.io
BETTER_AUTH_URL=

# Set to 'production' to disable debug logging.
#NODE_ENV=development

# Claude Code agent configuration.
# Command used to launch the ACP agent. Default: npx
# The ACP wrapper (@agentclientprotocol/claude-agent-acp) is required because
# the claude CLI is an interactive TUI, not an ACP agent.
#CLAUDE_COMMAND=npx

# Working directory passed to the claude subprocess. Required.
CLAUDE_CWD=

# Model passed to every new Claude agent session via the ACP wrapper's own
# ANTHROPIC_MODEL resolution (highest-priority source it checks, ahead of any
# persisted settings). Default: sonnet[1m] (current Sonnet, 1M-token context
# window) -- resolved by the ACP wrapper's fuzzy alias matcher, so it stays
# correct as Anthropic ships newer dated Sonnet releases. Falls back to the
# SDK's own default model if the account/API key lacks 1M-context access, or
# if this is unset. Override with any model id/alias the ACP wrapper accepts.
#ANTHROPIC_MODEL=sonnet[1m]

# Seconds before an idle agent session is evicted. Default: 300
#AGENT_IDLE_TIMEOUT_SECONDS=300

# Maximum number of concurrent agent sessions. Default: 5
#AGENT_MAX_SESSIONS=5

# Base run directory for per-turn key and identity tmpfs files.
# Production default: /run/tdr-code (Linux tmpfs).
# Override for local macOS dev where /run is not writable: /tmp/tdr-code
#TDR_CODE_RUN_DIR=/tmp/tdr-code

# Phase C: Path to the 32-byte AES-256-GCM master key file.
# Requirements: regular file, chmod 600, owned by the run uid, parent dir chmod 700.
# MUST be outside the Tier-1 backup tree (/storage/app-data/) to prevent a stolen
# backup from yielding both the DB (ciphertext) and the key (plaintext).
# One-time provisioning:
#   dd if=/dev/urandom bs=32 count=1 of=/run/tdr-code/master.key
#   chmod 600 /run/tdr-code/master.key
#   chmod 700 /run/tdr-code
#   chown <run-uid>:<run-uid> /run/tdr-code/master.key /run/tdr-code
# Also: disable core dumps for both processes (RLIMIT_CORE / ulimit -c 0) so a
# core dump does not re-introduce the master key into the backup-theft vector.
TDR_CODE_MASTER_KEY_FILE=

# Dev-only agent login (local development ONLY -- never set in production).
# When TDR_CODE_DEV_LOGIN=1 (and NODE_ENV!=production) and a secret is set,
# the app mounts POST /api/auth/dev-login, which mints a session for a
# synthetic user so an automated agent (e.g. a headless browser) can reach
# the console without the interactive Discord OAuth + guild-membership flow.
# buildAuth() refuses to boot if TDR_CODE_DEV_LOGIN=1 while
# NODE_ENV=production. See PLAN.md for the full design and threat model.
#TDR_CODE_DEV_LOGIN=1
#TDR_CODE_DEV_LOGIN_SECRET=   # e.g. openssl rand -hex 32
