# Port for the NestJS backend server.
# Default: 8082
#BACKEND_PORT=8082

# Port for the Next.js frontend server.
# Default: 8080
#PORT=8080

# Discord bot token.
DISCORD_API_TOKEN=

# Discord guild ID for registering slash commands in development.
DISCORD_GUILD_ID=

# Phase D: Discord OAuth2 client id + secret for "Login with Discord" (Better
# Auth). Get these from the Discord Developer Portal's OAuth2 page for the
# SAME Application as the bot (Application > OAuth2 > Client information) —
# they are distinct from DISCORD_API_TOKEN (the Bot page's token), which the
# bot process uses to connect to Discord's gateway, not to authenticate web
# users.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Phase D: Better Auth session-signing secret. This is a generated random
# secret, NOT something Discord issues — generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Phase D: Public base URL the app is served at, used to build the Discord
# OAuth redirect_uri and to derive secure-cookie defaults.
# Example: https://tdr-code.lilnas.io
BETTER_AUTH_URL=

# Set to 'production' to disable debug logging.
#NODE_ENV=development

# Claude Code agent configuration.
# Command used to launch the ACP agent. Default: npx
# The ACP wrapper (@agentclientprotocol/claude-agent-acp) is required because
# the claude CLI is an interactive TUI, not an ACP agent.
#CLAUDE_COMMAND=npx

# Working directory passed to the claude subprocess. Required.
CLAUDE_CWD=

# Seconds before an idle agent session is evicted. Default: 300
#AGENT_IDLE_TIMEOUT_SECONDS=300

# Maximum number of concurrent agent sessions. Default: 5
#AGENT_MAX_SESSIONS=5

# Base run directory for per-turn key and identity tmpfs files.
# Production default: /run/tdr-code (Linux tmpfs).
# Override for local macOS dev where /run is not writable: /tmp/tdr-code
#TDR_CODE_RUN_DIR=/tmp/tdr-code

# Phase C: Path to the 32-byte AES-256-GCM master key file.
# Requirements: regular file, chmod 600, owned by the run uid, parent dir chmod 700.
# MUST be outside the Tier-1 backup tree (/storage/app-data/) to prevent a stolen
# backup from yielding both the DB (ciphertext) and the key (plaintext).
# One-time provisioning:
#   dd if=/dev/urandom bs=32 count=1 of=/run/tdr-code/master.key
#   chmod 600 /run/tdr-code/master.key
#   chmod 700 /run/tdr-code
#   chown <run-uid>:<run-uid> /run/tdr-code/master.key /run/tdr-code
# Also: disable core dumps for both processes (RLIMIT_CORE / ulimit -c 0) so a
# core dump does not re-introduce the master key into the backup-theft vector.
TDR_CODE_MASTER_KEY_FILE=
