{
  "name": "@lilnas/tdr-code",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "packageManager": "pnpm@10.18.2",
  "prettier": "@lilnas/prettier",
  "engines": {
    "node": ">=22.22.1"
  },
  "files": [
    "./.next",
    "./dist"
  ],
  "scripts": {
    "build": "run-s build:frontend build:backend",
    "build:backend": "nest build -b swc --type-check",
    "build:frontend": "next build && cp .next/standalone/apps/tdr-code/server.js server.js",
    "clean": "rm -rf .next/ dist/ server.js .turbo/",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "dev": "run-p dev:main dev:frontend",
    "dev:main": "nest start -w -b swc | pino-pretty",
    "dev:bot": "node dist/bot-main",
    "dev:frontend": "dotenv -- next dev --turbopack",
    "lint": "run-p -l 'lint:!(fix)'",
    "lint:eslint": "eslint src",
    "lint:prettier": "prettier -c src",
    "lint:fix": "run-p -l lint:*:fix",
    "lint:eslint:fix": "eslint --fix src",
    "lint:prettier:fix": "prettier -w src",
    "start": "run-p start:main start:frontend",
    "start:main": "node dist/main",
    "start:bot": "node dist/bot-main",
    "start:frontend": "dotenv -- node server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@better-auth/drizzle-adapter": "1.6.23",
    "@lilnas/utils": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nestjs/common": "11.1.6",
    "@nestjs/core": "11.1.6",
    "@nestjs/platform-express": "11.1.6",
    "@nestjs/schedule": "6.0.1",
    "@tanstack/react-query": "5.90.2",
    "@tanstack/react-virtual": "^3.14.5",
    "@thallesp/nestjs-better-auth": "2.6.1",
    "better-auth": "1.6.23",
    "better-sqlite3": "^12.10.0",
    "clsx": "2.1.1",
    "commander": "^14.0.3",
    "cookie-parser": "^1.4.7",
    "cron-parser": "^5.5.0",
    "dayjs": "1.11.18",
    "diff": "^8.0.3",
    "discord.js": "^14.25.1",
    "dotenv": "17.2.3",
    "drizzle-orm": "^0.45.2",
    "helmet": "^8.0.0",
    "necord": "6.11.1",
    "nestjs-pino": "4.4.1",
    "next": "15.5.4",
    "npm-run-all": "4.1.5",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "smol-toml": "^1.6.0",
    "source-map-support": "0.5.21",
    "sshpk": "^1.18.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@lilnas/eslint": "workspace:*",
    "@nestjs/testing": "11.1.6",
    "@tailwindcss/postcss": "^4.1.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.9",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/sshpk": "^1.17.5",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^30.4.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "jest-environment-jsdom": "^30.3.0",
    "msw": "2.14.6",
    "tailwindcss": "^4.1.8",
    "ts-jest": "^29.3.4"
  }
}
