{
  "name": "@lilnas/tdr-code",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "packageManager": "pnpm@10.18.2",
  "prettier": "@lilnas/prettier",
  "files": [
    "./.next",
    "./dist"
  ],
  "scripts": {
    "build": "run-p build:*",
    "build:backend": "nest build -b swc --type-check",
    "build:frontend": "next build",
    "clean": "rm -rf .next/ dist/ .turbo/",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "dev": "run-p dev:backend dev:frontend",
    "dev:backend": "nest start -w -b swc | pino-pretty",
    "dev:frontend": "next dev -p ${PORT:-8083} --turbopack",
    "lint": "run-p -l 'lint:!(fix)'",
    "lint:eslint": "eslint src",
    "lint:prettier": "prettier -c src",
    "lint:fix": "run-p -l lint:*:fix",
    "lint:eslint:fix": "eslint --fix src",
    "lint:prettier:fix": "prettier -w src",
    "start": "run-p start:backend start:frontend",
    "start:backend": "node dist/main",
    "start:frontend": "node server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@lilnas/utils": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nestjs/common": "11.1.6",
    "@nestjs/core": "11.1.6",
    "@nestjs/platform-express": "11.1.6",
    "@nestjs/schedule": "6.0.1",
    "@tanstack/react-query": "5.90.2",
    "better-sqlite3": "^12.10.0",
    "clsx": "2.1.1",
    "commander": "^14.0.3",
    "cron-parser": "^5.5.0",
    "dayjs": "1.11.18",
    "diff": "^8.0.3",
    "discord.js": "^14.25.1",
    "dotenv": "17.2.3",
    "drizzle-orm": "^0.45.1",
    "necord": "6.11.1",
    "nestjs-pino": "4.4.1",
    "next": "15.5.4",
    "npm-run-all": "4.1.5",
    "pino-http": "11.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "smol-toml": "^1.6.0",
    "source-map-support": "0.5.21",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@lilnas/eslint": "workspace:*",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.1.8",
    "ts-jest": "^29.3.4"
  }
}
