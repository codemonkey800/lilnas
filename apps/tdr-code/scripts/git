#!/usr/bin/env bash
# git — PATH wrapper injected by tdr-code into the Claude subprocess environment.
#
# Reads per-turn identity from /run/tdr-code/identity/$TDR_CHANNEL_ID/ and
# exports git env vars before delegating to the real git binary ($TDR_REAL_GIT).
#
# Files written by GitTurnContext.begin() and removed by GitTurnContext.end():
#   name        — GIT_AUTHOR_NAME / GIT_COMMITTER_NAME
#   email       — GIT_AUTHOR_EMAIL / GIT_COMMITTER_EMAIL
#   ssh_command — GIT_SSH_COMMAND (configured key path or blocking wrapper)
#
# If no identity dir exists (no active turn or non-git cwd) git runs unmodified.

set -euo pipefail

IDENTITY_DIR="/run/tdr-code/identity/${TDR_CHANNEL_ID:-}"

if [ -n "${TDR_CHANNEL_ID:-}" ] && [ -d "$IDENTITY_DIR" ]; then
  GIT_AUTHOR_NAME=$(cat "$IDENTITY_DIR/name")
  GIT_AUTHOR_EMAIL=$(cat "$IDENTITY_DIR/email")
  export GIT_AUTHOR_NAME
  export GIT_AUTHOR_EMAIL
  export GIT_COMMITTER_NAME="$GIT_AUTHOR_NAME"
  export GIT_COMMITTER_EMAIL="$GIT_AUTHOR_EMAIL"
  if [ -f "$IDENTITY_DIR/ssh_command" ]; then
    GIT_SSH_COMMAND=$(cat "$IDENTITY_DIR/ssh_command")
    export GIT_SSH_COMMAND
  fi
fi

exec "${TDR_REAL_GIT}" "$@"
