# Copy this file to .env and customize as needed.
# .env is gitignored; this example file is committed.

# Database
DATABASE_URL=postgresql://tdr_bot:changeme@tdr-bot-db:5432/tdr_bot

POSTGRES_DB=tdr_bot
POSTGRES_USER=tdr_bot
POSTGRES_PASSWORD=changeme

# Local Postgres port. Use a non-default port (e.g. 5433) to avoid
# conflicting with any Postgres instance already running on 5432.
#POSTGRES_PORT=5433

# Host directory to mount as persistent Postgres storage. When set, the dev
# database survives container restarts. When unset, a fresh database is
# created in an ephemeral container each time `pnpm dev` runs.
#DB_PATH=/path/to/local/tdr-bot-db

# App specific
# Port for the Next.js dev server. Default: 8080
#PORT=3000
# Port for the NestJS backend server. Default: 8081
#BACKEND_PORT=8082
BACKEND_PORT=8081
FRONTEND_PORT=8080
DOWNLOAD_POLL_RETRIES=50
DOWNLOAD_POLL_DURATION_MS=2000
TZ=America/Los_Angeles

DISCORD_API_TOKEN=token
DISCORD_CLIENT_ID=id
DISCORD_DEV_GUILD_ID=id

# Equations API
EQUATIONS_API_KEY=key
EQUATIONS_URL=https://example.com

# MinIO
MINIO_ACCESS_KEY=key
MINIO_HOST=host
MINIO_PORT=9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_SECRET_KEY=key

# API keys
HUGGING_FACE_TOKEN=key
OPENAI_API_KEY=key
SERP_API_KEY=key
TAVILY_API_KEY=key

# Discord bot tokens used by scripts in scripts/*.ts.
# DEV token is for the dev bot (must have Manage Channels permission in the dev guild).
# PROD token is for the production bot (used when targeting the live server).
#DISCORD_SCRIPTS_DEV_TOKEN=
#DISCORD_SCRIPTS_PROD_TOKEN=
