# Local development overrides for the tdr-bot dev server.
#
# Copy this file to .env.dev and customize as needed.
# Values here take precedence over infra/.env.tdr-bot.
# .env.dev is gitignored; this example file is committed.

# Port for the Next.js dev server.
# Default: 8080
#PORT=3000

# Port for the NestJS backend server.
# Default: 8081
#BACKEND_PORT=8082

# Local Postgres port. Use a non-default port (e.g. 5433) to avoid
# conflicting with any Postgres instance already running on 5432.
POSTGRES_PORT=5433

# Host directory to mount as persistent Postgres storage.
# When set, the dev database survives container restarts and the data
# is stored at this path on your machine. When unset, a fresh database
# is created in an ephemeral container each time `pnpm dev` runs.
#DB_PATH=/path/to/local/tdr-bot-db

# Discord bot tokens used by scripts in scripts/*.ts.
# DEV token is for the dev bot (must have Manage Channels permission in the dev guild).
# PROD token is for the production bot (used when targeting the live server).
#DISCORD_SCRIPTS_DEV_TOKEN=
#DISCORD_SCRIPTS_PROD_TOKEN=
