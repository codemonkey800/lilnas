{
  "name": "@lilnas/tdr-bot",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "packageManager": "pnpm@10.18.2",
  "prettier": "@lilnas/prettier",
  "files": [
    "./.next",
    "./dist"
  ],
  "scripts": {
    "build": "run-p build:*",
    "build:backend": "nest build -b swc --type-check",
    "build:frontend": "next build",
    "clean": "rm -rf .next/ dist/ .turbo/",
    "deploy": "fly deploy",
    "dev": "./scripts/dev.sh",
    "dev:backend": "nest start -w -b swc | pino-pretty",
    "dev:frontend": "next dev -p ${PORT:-8080} --turbopack",
    "dev:servers": "run-p dev:backend dev:frontend",
    "dev:graph-test": "GRAPH_TEST=true ./scripts/dev.sh backend",
    "lint": "run-p -l 'lint:!(fix)'",
    "lint:eslint": "eslint src",
    "lint:prettier": "prettier -c src",
    "lint:fix": "run-p -l lint:*:fix",
    "lint:eslint:fix": "eslint --fix src",
    "lint:prettier:fix": "prettier -w src",
    "start": "run-s start:migrate start:servers",
    "start:servers": "run-p start:backend start:frontend",
    "start:backend": "node dist/main",
    "start:frontend": "node server.js",
    "start:migrate": "node dist/db/migrate.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@langchain/community": "0.3.57",
    "@langchain/core": "0.3.78",
    "@langchain/langgraph": "0.4.9",
    "@langchain/openai": "0.6.15",
    "@langchain/tavily": "^1.2.0",
    "@libsql/client": "0.15.15",
    "@lilnas/media": "workspace:*",
    "@lilnas/utils": "workspace:*",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@nestjs/common": "11.1.6",
    "@nestjs/core": "11.1.6",
    "@nestjs/event-emitter": "3.0.1",
    "@nestjs/platform-express": "11.1.6",
    "@nestjs/schedule": "6.0.1",
    "@tanstack/react-query": "5.90.2",
    "@tavily/core": "0.5.12",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "async-mutex": "^0.5.0",
    "axios": "1.12.2",
    "cheerio": "1.1.2",
    "chokidar": "4.0.3",
    "clsx": "2.1.1",
    "cron": "^4.3.3",
    "dayjs": "1.11.18",
    "dedent": "1.7.0",
    "discord.js": "14.23.2",
    "dotenv": "17.2.3",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.37.0",
    "fs-extra": "11.3.2",
    "http-server": "14.1.1",
    "jotai": "2.15.0",
    "lodash": "4.17.21",
    "lru-cache": "11.2.2",
    "minio": "8.0.6",
    "nanoid": "5.1.6",
    "necord": "6.11.1",
    "nestjs-minio": "2.6.2",
    "nestjs-pino": "4.4.1",
    "next": "15.5.4",
    "node-docker-api": "1.1.22",
    "node-schedule": "2.1.1",
    "npm-run-all": "4.1.5",
    "openai": "6.3.0",
    "pg": "^8.18.0",
    "pino-http": "11.0.0",
    "prom-client": "^15.1.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "reflect-metadata": "0.2.2",
    "remark": "15.0.1",
    "rxjs": "7.8.1",
    "source-map-support": "0.5.21",
    "ts-pattern": "5.8.0",
    "unist-util-visit": "5.0.0",
    "uuid": "13.0.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/cron": "^2.4.3",
    "@types/pg": "^8.16.0",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.1.8"
  }
}
