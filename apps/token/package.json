{
  "name": "@lilnas/token",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "prettier": "@lilnas/prettier",
  "files": [
    "./.next",
    "./dist",
    "./drizzle"
  ],
  "scripts": {
    "prebuild": "tsx scripts/generate-apps.ts",
    "build": "run-p build:*",
    "build:backend": "nest build -b swc --type-check",
    "build:frontend": "next build",
    "clean": "rm -rf .next/ dist/ .turbo/ src/generated/",
    "dev": "lilnas dev",
    "dev:backend": "nest start -w -b swc | pino-pretty",
    "dev:frontend": "next dev -p ${PORT:-8080} --turbopack",
    "predev:start": "tsx scripts/generate-apps.ts",
    "dev:start": "run-p dev:backend dev:frontend",
    "lint": "run-p -l 'lint:!(fix)'",
    "lint:eslint": "eslint src",
    "lint:prettier": "prettier -c src",
    "lint:fix": "run-p -l lint:*:fix",
    "lint:eslint:fix": "eslint --fix src",
    "lint:prettier:fix": "prettier -w src",
    "start": "run-s start:migrate start:servers",
    "start:servers": "run-p start:backend start:frontend",
    "start:backend": "node dist/main",
    "start:frontend": "node server.js",
    "start:migrate": "node dist/db/migrate.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@lilnas/utils": "workspace:*",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@nestjs/common": "11.1.6",
    "@nestjs/core": "11.1.6",
    "@nestjs/platform-express": "11.1.6",
    "@tanstack/react-query": "5.90.2",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "bcrypt": "^5.1.1",
    "dotenv": "17.2.3",
    "drizzle-orm": "^0.45.1",
    "nanoid": "5.1.6",
    "nestjs-pino": "4.4.1",
    "nestjs-zod": "^4.3.1",
    "next": "15.5.4",
    "npm-run-all": "4.1.5",
    "pg": "^8.18.0",
    "pino-http": "11.0.0",
    "prom-client": "^15.1.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "source-map-support": "0.5.21",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@lilnas/cli": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "4.20.6"
  }
}
