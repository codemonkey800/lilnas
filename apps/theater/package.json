{
  "name": "@lilnas/theater",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "packageManager": "pnpm@10.18.2",
  "prettier": "@lilnas/prettier",
  "files": [
    "./.next",
    "./dist"
  ],
  "scripts": {
    "build": "run-p build:*",
    "build:backend": "nest build -b swc --type-check",
    "build:frontend": "next build",
    "clean": "rm -rf .next/ dist/ .turbo/",
    "dev": "lilnas dev",
    "dev:backend": "nest start -w -b swc | pino-pretty",
    "dev:frontend": "next dev -p 8080",
    "dev:start": "run-p dev:backend dev:frontend",
    "lint": "run-p -l 'lint:!(fix)'",
    "lint:eslint": "eslint src",
    "lint:prettier": "prettier -c src",
    "lint:fix": "run-p -l lint:*:fix",
    "lint:eslint:fix": "eslint --fix src",
    "lint:prettier:fix": "prettier -w src",
    "start": "run-p start:*",
    "start:backend": "node dist/main",
    "start:frontend": "node server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@lilnas/utils": "workspace:*",
    "@nestjs/common": "11.1.6",
    "@nestjs/core": "11.1.6",
    "@nestjs/platform-express": "11.1.6",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "clsx": "2.1.1",
    "dotenv": "17.2.3",
    "next": "15.5.20",
    "npm-run-all": "4.1.5",
    "nestjs-pino": "4.4.1",
    "pino-http": "11.0.0",
    "prom-client": "^15.1.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "source-map-support": "0.5.21",
    "tailwind-merge": "3.3.1"
  },
  "devDependencies": {
    "@lilnas/cli": "workspace:*",
    "@types/jest": "29.5.14",
    "jest": "29.7.0",
    "ts-jest": "29.2.6",
    "typescript": "5.9.3"
  }
}
