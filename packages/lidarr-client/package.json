{
  "name": "@lilnas/lidarr-client",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "prettier": "@lilnas/prettier",
  "exports": {
    ".": "./dist/index.js",
    "./react": "./dist/react.js"
  },
  "scripts": {
    "build": "tsc -p .",
    "clean": "rm -rf dist/ .turbo/",
    "lint": "run-p -l 'lint:!(fix)'",
    "lint:eslint": "eslint src",
    "lint:prettier": "prettier -c src",
    "lint:fix": "run-p -l lint:*:fix",
    "lint:eslint:fix": "eslint --fix src",
    "lint:prettier:fix": "prettier -w src",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "socket.io-client": "^4.8.1"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lilnas/eslint": "workspace:*",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18.3.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "npm-run-all": "4.1.5",
    "react": "^18",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.4.6"
  }
}
