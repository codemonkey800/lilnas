{
  "name": "@lilnas/sync",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "prettier": "@lilnas/prettier",
  "scripts": {
    "build": "next build",
    "clean": "rm -rf .next/ *.tsbuildinfo .turbo/",
    "dev": "next dev --turbopack -p 8080",
    "dev:prod": "run-s -l build start",
    "lint": "run-p -l 'lint:!(fix)'",
    "lint:eslint": "eslint src",
    "lint:prettier": "prettier -c src",
    "lint:fix": "run-p -l lint:*:fix",
    "lint:eslint:fix": "eslint --fix src",
    "lint:prettier:fix": "prettier -w src",
    "start": "NODE_ENV=production node server.js",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@lilnas/utils": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "next": "15.5.4",
    "bcryptjs": "^2.4.3",
    "next-auth": "5.0.0-beta.30",
    "pg": "^8.13.0",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@lilnas/eslint": "workspace:*",
    "@lilnas/prettier": "workspace:*",
    "@types/node": "^22.15.29",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "drizzle-kit": "^0.30.0",
    "npm-run-all2": "^8.0.4",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
