{
  "name": "apps",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "next build",
    "clean": "run-p clean:*",
    "clean:build": "rm -rf .next next-env.d.ts",
    "clean:modules": "rm -rf node_modules",
    "dev": "next dev --turbopack -p 8080",
    "dev:prod": "run-s build start",
    "lint": "run-p -l 'lint:!(fix)'",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier -c .",
    "lint:fix": "run-p -l 'lint:*:fix'",
    "lint:eslint:fix": "pnpm lint --fix",
    "start": "next start -p 8080"
  },
  "dependencies": {
    "next": "15.1.0",
    "node-docker-api": "1.1.22",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.10.1",
    "@types/react": "18.3.13",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "eslint": "9.17.0",
    "eslint-config-lilnas": "workspace:*",
    "postcss": "8.4.49",
    "tailwind": "4.0.0",
    "tailwindcss": "3.4.16"
  }
}
