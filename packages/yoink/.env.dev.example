# Local development overrides for the yoink dev server.
#
# Copy this file to .env.dev and customize as needed.
# Values here take precedence over infra/.env.yoink.
# .env.dev is gitignored; this example file is committed.

# Port for the Next.js dev server.
# Default: 8080
#PORT=3000

# Host directory to mount as persistent Postgres storage.
# When set, the dev database survives container restarts and the data
# is stored at this path on your machine. When unset, a fresh database
# is created in an ephemeral container each time `pnpm dev` runs.
#DB_PATH=/path/to/local/yoink-db
