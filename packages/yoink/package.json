{
  "name": "@lilnas/yoink",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "prettier": "@lilnas/prettier",
  "scripts": {
    "build": "run-p build:*",
    "build:backend": "nest build -b swc --type-check",
    "build:frontend": "next build",
    "clean": "rm -rf .next/ dist/ *.tsbuildinfo .turbo/",
    "dev": "./scripts/dev.sh",
    "dev:backend": "nest start -w -b swc | pino-pretty",
    "dev:frontend": "next dev --turbopack -p ${PORT:-8080}",
    "dev:servers": "run-p dev:backend dev:frontend",
    "lint": "run-p -l 'lint:!(fix)'",
    "lint:eslint": "eslint src",
    "lint:prettier": "prettier -c src",
    "lint:fix": "run-p -l lint:*:fix",
    "lint:eslint:fix": "eslint --fix src",
    "lint:prettier:fix": "prettier -w src",
    "start": "run-p start:*",
    "start:backend": "node dist/main",
    "start:frontend": "NODE_ENV=production node server.js",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@lilnas/media": "workspace:*",
    "@lilnas/utils": "workspace:*",
    "@mui/icons-material": "7.3.4",
    "@mui/material": "7.3.4",
    "@mui/material-nextjs": "7.3.3",
    "@nestjs/common": "11.1.6",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "11.1.6",
    "@nestjs/event-emitter": "3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "11.1.6",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "6.0.1",
    "@nestjs/websockets": "^11.1.16",
    "@tanstack/react-query": "5.90.2",
    "@tanstack/react-virtual": "^3.13.19",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "dayjs": "1.11.18",
    "dotenv": "17.2.3",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.0",
    "nestjs-pino": "4.4.1",
    "next": "16.1.6",
    "npm-run-all": "4.1.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.18.0",
    "pino-http": "11.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "socket.io": "^4.8.3",
    "source-map-support": "0.5.21",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "pino-pretty": "13.1.2"
  }
}
