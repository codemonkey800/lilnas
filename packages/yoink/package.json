{
  "name": "@lilnas/yoink",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "prettier": "@lilnas/prettier",
  "scripts": {
    "build": "next build",
    "clean": "rm -rf .next/ *.tsbuildinfo .turbo/",
    "dev": "./scripts/dev.sh",
    "dev:prod": "run-s -l build start",
    "lint": "run-p -l 'lint:!(fix)'",
    "lint:eslint": "eslint src",
    "lint:prettier": "prettier -c src",
    "lint:fix": "run-p -l lint:*:fix",
    "lint:eslint:fix": "eslint --fix src",
    "lint:prettier:fix": "prettier -w src",
    "start": "NODE_ENV=production node server.js",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@auth/core": "0.41.0",
    "@auth/drizzle-adapter": "^1.11.1",
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@lilnas/utils": "workspace:*",
    "@mui/icons-material": "7.3.4",
    "@mui/material": "7.3.4",
    "@mui/material-nextjs": "7.3.3",
    "drizzle-orm": "^0.45.1",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "pg": "^8.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9"
  }
}
