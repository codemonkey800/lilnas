DATABASE_URL=postgresql://yoink:changeme@yoink-db:5432/yoink

POSTGRES_DB=yoink
POSTGRES_USER=yoink
POSTGRES_PASSWORD=changeme

JWT_SECRET=changeme
JWT_EXPIRATION=24h

GOOGLE_CLIENT_ID=id
GOOGLE_CLIENT_SECRET=secret
# Public-facing callback URL. Must match an authorized redirect URI in Google Cloud Console.
# Local dev:  http://localhost:8080/api/auth/google/callback
# Production: https://yoink.lilnas.io/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

ADMIN_EMAIL=admin@example.com

# Agent auth bypass -- set to a strong random secret to enable GET /api/auth/agent-login?key=<value>
# Leave unset (or remove) to disable the endpoint entirely.
AGENT_API_KEY=

# Media Services
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=changeme

RADARR_URL=http://radarr:7878
RADARR_API_KEY=changeme
