        {
          "expr": "sum(increase(yoink_downloads_completed_total{status=\"cancelled\"}[1h])) or vector(0)",
          "legendFormat": "cancelled",
          "refId": "C"
        },
        {
          "expr": "sum(increase(yoink_downloads_completed_total{status=\"not_found\"}[1h])) or vector(0)",
          "legendFormat": "not found",
          "refId": "D"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "pieType": "pie",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },
