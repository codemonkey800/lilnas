        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      }
    },
    {
      "id": 14,
      "type": "piechart",
      "title": "Download Outcomes (1h)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(yoink_downloads_completed_total{status=\"completed\"}[1h])) or vector(0)",
          "legendFormat": "completed",
          "refId": "A"
        },
        {
          "expr": "sum(increase(yoink_downloads_completed_total{status=\"failed\"}[1h])) or vector(0)",
