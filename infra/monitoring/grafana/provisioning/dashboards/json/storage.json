          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 32,
      "type": "stat",
      "title": "Total Read Throughput",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(irate(node_disk_read_bytes_total{device=~\"sd.*|nvme.*|vd.*|xvd.*\"}[5m]))",
