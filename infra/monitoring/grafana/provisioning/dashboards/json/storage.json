      "id": 31,
      "type": "stat",
      "title": "Current I/O Operations In Flight",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(node_disk_io_now{device=~\"sd.*|nvme.*|vd.*|xvd.*\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
